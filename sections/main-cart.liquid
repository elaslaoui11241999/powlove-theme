<section class="section">
  <div class="page-width" data-cart data-free-ship="{{ section.settings.free_ship | times: 100 }}">

    {%- if cart.item_count == 0 -%}
      <div class="cart-empty">
        <div style="font-size:4rem;">🐾</div>
        <h2>{{ 'cart.general.empty' | t }}</h2>
        <p style="color:var(--color-ink-soft);">Aún no has añadido nada. ¡Tu mascota te lo agradecerá!</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary btn--lg" style="margin-top:16px;">{{ 'cart.general.continue_shopping' | t }}</a>
      </div>
    {%- else -%}

      <div class="cart-head">
        <h1>{{ 'cart.general.title' | t }}</h1>
        <span>{{ cart.item_count }} {% if cart.item_count == 1 %}artículo{% else %}artículos{% endif %}</span>
      </div>

      {%- if section.settings.show_shipbar -%}
        {%- assign threshold = section.settings.free_ship | times: 100 -%}
        {%- assign remaining = threshold | minus: cart.total_price -%}
        <div class="cart-ship">
          <div class="cart-ship__label">
            <span class="ico">🚚</span>
            {%- if cart.total_price >= threshold -%}
              <span>¡Genial! Tienes <b style="color:#3E8E5A">envío gratis</b> 🎉</span>
            {%- else -%}
              <span>Te faltan <b style="color:var(--color-accent-dark)">{{ remaining | money }}</b> para el envío gratis</span>
            {%- endif -%}
          </div>
          <div class="cart-ship__track">
            <div class="cart-ship__fill" style="width:{% if cart.total_price >= threshold %}100{% else %}{{ cart.total_price | times: 100 | divided_by: threshold }}{% endif %}%"></div>
          </div>
        </div>
      {%- endif -%}

      {% form 'cart', cart %}
        <div class="cart-grid">
          <div>
            <div class="cart-rows">
              {%- for item in cart.items -%}
                {%- assign vname = item.variant.title | downcase -%}
                {%- assign sw = '' -%}
                {%- if vname contains 'roj' or vname contains 'red' %}{% assign sw = '#D0342C' %}
                {%- elsif vname contains 'verd' or vname contains 'green' %}{% assign sw = '#3E8E5A' %}
                {%- elsif vname contains 'azul' or vname contains 'blue' %}{% assign sw = '#2A6FB0' %}
                {%- elsif vname contains 'gris' or vname contains 'gray' or vname contains 'grey' %}{% assign sw = '#9A9A9A' %}
                {%- elsif vname contains 'negr' or vname contains 'black' %}{% assign sw = '#2A1B12' %}
                {%- elsif vname contains 'blanc' or vname contains 'white' %}{% assign sw = '#F2EDE3' %}
                {%- endif -%}
                <div class="cart-row">
                  <a href="{{ item.url }}" class="cart-row__media">
                    {%- if item.image -%}
                      <img src="{{ item.image | image_url: width: 220 }}" alt="{{ item.title | escape }}">
                    {%- else -%}
                      {% render 'media-placeholder', uid: item.key, label: 'foto' %}
                    {%- endif -%}
                  </a>
                  <div>
                    <a href="{{ item.url }}" class="cart-row__name">{{ item.product.title }}</a>
                    {%- unless item.variant.title contains 'Default' -%}
                      <div class="cart-row__opt">{% if sw != blank %}<span class="cart-row__sw" style="background:{{ sw }}"></span>{% endif %}{{ item.variant.title }}</div>
                    {%- endunless -%}
                    {%- if item.variant.available -%}<div class="cart-row__stock">● En stock</div>{%- endif -%}
                    <div class="cart-row__controls">
                      <div class="qty">
                        <button type="button" onclick="this.nextElementSibling.stepDown();this.closest('form').submit()" aria-label="Menos">−</button>
                        <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" onchange="this.form.submit()" aria-label="Cantidad">
                        <button type="button" onclick="this.previousElementSibling.stepUp();this.closest('form').submit()" aria-label="Más">+</button>
                      </div>
                      <a href="{{ item.url_to_remove }}" class="cart-row__remove">🗑 {{ 'cart.general.remove' | t }}</a>
                    </div>
                  </div>
                  <div class="cart-row__right">
                    <div class="cart-row__price">{{ item.final_line_price | money }}</div>
                    {%- if item.original_line_price > item.final_line_price -%}
                      <span class="cart-row__was">{{ item.original_line_price | money }}</span>
                    {%- endif -%}
                    {%- if item.quantity > 1 -%}<span class="cart-row__each">{{ item.final_price | money }} c/u</span>{%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>

            {%- if section.settings.upsell_collection != blank -%}
              {%- assign up = collections[section.settings.upsell_collection] -%}
              {%- if up.products.size > 0 -%}
                <div class="cart-upsell">
                  <h3>🐾 Completa tu compra</h3>
                  <div class="cart-upsell__track">
                    {%- for product in up.products limit: 3 -%}
                      <div class="upsell">
                        <a href="{{ product.url }}" class="upsell__img">
                          {%- if product.featured_image -%}<img src="{{ product.featured_image | image_url: width: 120 }}" alt="" style="width:100%;height:100%;object-fit:cover;">{%- else -%}{% render 'media-placeholder', uid: product.id, label: '' %}{%- endif -%}
                        </a>
                        <div class="upsell__info">
                          <div class="upsell__name">{{ product.title | truncate: 32 }}</div>
                          <div class="upsell__price">{{ product.price | money }}</div>
                        </div>
                        <form method="post" action="{{ routes.cart_add_url }}">
                          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                          <button type="submit" class="upsell__add" aria-label="Añadir">+</button>
                        </form>
                      </div>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endif -%}
            {%- endif -%}
          </div>

          <aside class="cart-summary">
            <h3>Resumen del pedido</h3>
            <div class="cart-summary__row"><span>{{ 'cart.general.subtotal' | t }}</span><span>{{ cart.total_price | money }}</span></div>
            {%- if cart.total_discount > 0 -%}
              <div class="cart-summary__row"><span>Descuento</span><span class="free">−{{ cart.total_discount | money }}</span></div>
            {%- endif -%}
            <div class="cart-summary__row muted">
              <span>Envío</span>
              {%- assign threshold = section.settings.free_ship | times: 100 -%}
              {%- if cart.total_price >= threshold -%}<span class="free">GRATIS</span>{%- else -%}<span>Calculado en el pago</span>{%- endif -%}
            </div>

            <div class="cart-code">
              <input type="text" name="discount" placeholder="Código de descuento">
              <button type="button">Aplicar</button>
            </div>

            <div class="cart-summary__total">
              <span>Total <small>(IVA incl.)</small></span>
              <b>{{ cart.total_price | money }}</b>
            </div>

            <button type="submit" name="checkout" class="btn btn--primary btn--block btn--lg" style="margin-top:14px;">🔒 {{ 'cart.general.checkout' | t }}</button>
            <a href="{{ routes.all_products_collection_url }}" class="btn btn--ghost btn--block" style="margin-top:10px;">{{ 'cart.general.continue_shopping' | t }}</a>

            <div class="cart-trust">
              <div>🔒 Pago 100% seguro y cifrado</div>
              <div>↩️ Devolución gratis en 30 días</div>
              <div>🚀 Entrega estimada 8-18 días</div>
            </div>
            <div class="cart-pay">
              <span class="pay__chip">VISA</span>
              <span class="pay__chip">Mastercard</span>
              <span class="pay__chip">PayPal</span>
              <span class="pay__chip">Bizum</span>
              <span class="pay__chip">G Pay</span>
            </div>
          </aside>
        </div>
      {% endform %}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Carrito",
  "settings": [
    { "type": "checkbox", "id": "show_shipbar", "label": "Mostrar barra de envío gratis", "default": true },
    { "type": "range", "id": "free_ship", "label": "Umbral envío gratis (€)", "min": 20, "max": 100, "step": 5, "default": 40 },
    { "type": "collection", "id": "upsell_collection", "label": "Colección de 'Completa tu compra'" }
  ]
}
{% endschema %}
