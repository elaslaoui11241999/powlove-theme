<section class="section">
  <div class="page-width">
    <div class="sec-head">
      <h1>{{ 'general.search.title' | t }}</h1>
      {% form 'search' %}
        <div class="newsletter__form" style="margin:24px auto 0;">
          <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}">
          <button type="submit" class="btn btn--primary btn--lg">{{ 'general.search.search' | t }}</button>
        </div>
      {% endform %}
    </div>

    {%- if search.performed -%}
      {%- if search.results.size == 0 -%}
        <p style="text-align:center;">{{ 'general.search.no_results' | t: terms: search.terms }}</p>
      {%- else -%}
        <p style="text-align:center;color:var(--color-ink-soft);margin-bottom:28px;">
          {{ 'general.search.results_with_count' | t: count: search.results_count, terms: search.terms }}
        </p>
        <div class="product-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'product-card', product: item %}
            {%- else -%}
              <a href="{{ item.url }}" class="card"><div class="card__body"><span class="card__title">{{ item.title }}</span></div></a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{ "name": "Búsqueda", "settings": [] }
{% endschema %}
