<section class="section">
  <div class="page-width account-narrow">
    <div class="sec-head"><h1>Nueva contraseña</h1><p style="color:var(--color-ink-soft);">Introduce tu nueva contraseña.</p></div>
    <div class="account-card">
      {% form 'reset_customer_password' %}
        {{ form.errors | default_errors }}
        <label class="field"><span>Nueva contraseña</span><input type="password" name="customer[password]" required></label>
        <label class="field"><span>Confirmar contraseña</span><input type="password" name="customer[password_confirmation]" required></label>
        <button type="submit" class="btn btn--primary btn--block btn--lg" style="margin-top:16px;">Restablecer contraseña</button>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Restablecer contraseña", "settings": [] }
{% endschema %}
