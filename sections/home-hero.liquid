{%- liquid
  assign img_main = section.settings.image_main
  assign img_tr = section.settings.image_tr
  assign img_br = section.settings.image_br
-%}
<section class="plh">
  <div class="page-width plh__grid">
    <div class="plh__content">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">🐾 {{ section.settings.eyebrow }}</span>{%- endif -%}
      <h1 class="plh__title">{{ section.settings.title }}</h1>
      <p class="plh__lead">{{ section.settings.lead }}</p>
      <div class="plh__cta">
        <a href="{{ section.settings.btn1_link | default: '#productos' }}" class="btn btn--primary btn--lg">{{ section.settings.btn1_label }}</a>
        {%- if section.settings.btn2_label != blank -%}<a href="{{ section.settings.btn2_link | default: '#bundle' }}" class="btn btn--ghost btn--lg">{{ section.settings.btn2_label }}</a>{%- endif -%}
      </div>
      <div class="plh__proof">
        <div class="plh__avatars">
          <span style="background:#E8702A">SM</span><span style="background:#3E8E5A">CR</span><span style="background:#2A6FB0">AG</span><span style="background:#E58CA8">JP</span>
        </div>
        <div>{% render 'stars', rating: 5 %}<div style="font-weight:800">{{ section.settings.proof }}</div></div>
      </div>
    </div>
    <div class="plh__stage">
      <div class="plh__card plh__card--main"><img src="{% if img_main %}{{ img_main | image_url: width: 800 }}{% else %}{{ 'pl-seatbelt-hero.png' | asset_url }}{% endif %}" alt="" loading="eager"></div>
      <div class="plh__card plh__card--tr"><img src="{% if img_tr %}{{ img_tr | image_url: width: 600 }}{% else %}{{ 'pl-leash-top.png' | asset_url }}{% endif %}" alt=""></div>
      <div class="plh__card plh__card--br"><img src="{% if img_br %}{{ img_br | image_url: width: 500 }}{% else %}{{ 'pl-scooper-card.png' | asset_url }}{% endif %}" alt=""></div>
      <div class="plh__bubble plh__bubble--1">⭐ 4.9 / 5</div>
      <div class="plh__bubble plh__bubble--2">🚀 {{ section.settings.bubble | default: 'Envío rápido' }}</div>
    </div>
  </div>
</section>

{% stylesheet %}
.plh{position:relative;overflow:hidden}
.plh::before{content:"";position:absolute;width:620px;height:620px;border-radius:50%;background:radial-gradient(circle,var(--color-accent-soft),transparent 70%);top:-180px;right:-160px;z-index:0}
.plh__grid{position:relative;z-index:1;display:grid;grid-template-columns:1.02fr .98fr;gap:48px;align-items:center;padding:clamp(40px,6vw,80px) 0}
.plh__title{font-size:clamp(2.4rem,5.5vw,4.2rem)}
.plh__lead{font-size:1.22rem;color:var(--color-ink-soft);max-width:46ch}
.plh__cta{display:flex;gap:14px;flex-wrap:wrap;margin-top:30px}
.plh__proof{display:flex;align-items:center;gap:14px;margin-top:32px}
.plh__avatars{display:flex}
.plh__avatars span{width:42px;height:42px;border-radius:999px;display:grid;place-items:center;font-family:'Fredoka',sans-serif;font-weight:700;color:#fff;border:3px solid var(--color-bg);margin-left:-12px;font-size:.85rem}
.plh__avatars span:first-child{margin-left:0}
.plh__stage{position:relative;aspect-ratio:1/1}
.plh__card{position:absolute;background:var(--color-surface);border:1px solid var(--color-border);border-radius:24px;box-shadow:0 30px 60px -30px rgba(42,27,18,.5);overflow:hidden}
.plh__card img{width:100%;height:100%;object-fit:cover}
.plh__card--main{width:62%;height:72%;top:4%;left:6%;z-index:2;transform:rotate(-3deg)}
.plh__card--tr{width:44%;height:46%;top:0;right:0;z-index:3;transform:rotate(4deg)}
.plh__card--br{width:50%;height:44%;bottom:0;right:8%;z-index:4;transform:rotate(-2deg)}
.plh__bubble{position:absolute;z-index:5;background:var(--color-surface);border-radius:999px;padding:11px 17px;box-shadow:0 16px 36px -16px rgba(42,27,18,.4);font-weight:700;display:flex;align-items:center;gap:8px;font-size:.95rem}
.plh__bubble--1{bottom:14%;left:-2%}
.plh__bubble--2{top:46%;right:-3%}
@media(max-width:860px){.plh__grid{grid-template-columns:1fr;gap:30px}.plh__stage{max-width:460px;margin:0 auto;width:100%}}
{% endstylesheet %}

{% schema %}
{
  "name": "Hero collage",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Texto pequeño", "default": "La tienda que tus mascotas merecen" },
    { "type": "richtext", "id": "title", "label": "Título", "default": "<p>Todo el amor para tu mascota, en un solo sitio</p>" },
    { "type": "textarea", "id": "lead", "label": "Descripción", "default": "Los accesorios más prácticos para perros y gatos: paseos sin estrés, viajes seguros y limpieza al instante. Calidad premium, precio justo y envío a toda España." },
    { "type": "text", "id": "btn1_label", "label": "Botón 1", "default": "Ver productos 🐾" },
    { "type": "url", "id": "btn1_link", "label": "Enlace botón 1" },
    { "type": "text", "id": "btn2_label", "label": "Botón 2", "default": "Pack ahorro −30%" },
    { "type": "url", "id": "btn2_link", "label": "Enlace botón 2" },
    { "type": "text", "id": "proof", "label": "Prueba social", "default": "4.9/5 · +5.000 mascotas felices" },
    { "type": "text", "id": "bubble", "label": "Burbuja", "default": "Envío rápido" },
    { "type": "header", "content": "Imágenes (opcional: usa las del tema si lo dejas vacío)" },
    { "type": "image_picker", "id": "image_main", "label": "Imagen principal" },
    { "type": "image_picker", "id": "image_tr", "label": "Imagen arriba-derecha" },
    { "type": "image_picker", "id": "image_br", "label": "Imagen abajo-derecha" }
  ],
  "presets": [ { "name": "Hero collage" } ]
}
{% endschema %}
