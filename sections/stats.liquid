<section class="section">
  <div class="page-width">
    <div class="stats">
      {%- for block in section.blocks -%}
        <div class="stats__item" {{ block.shopify_attributes }}>
          <div class="stats__num">{{ block.settings.number }}</div>
          <div class="stats__label">{{ block.settings.label }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Cifras",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "stat",
      "name": "Cifra",
      "settings": [
        { "type": "text", "id": "number", "label": "Número", "default": "5K+" },
        { "type": "text", "id": "label", "label": "Etiqueta", "default": "Clientes felices" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cifras",
      "blocks": [
        { "type": "stat", "settings": { "number": "5K+", "label": "Clientes felices" } },
        { "type": "stat", "settings": { "number": "9", "label": "Productos top" } },
        { "type": "stat", "settings": { "number": "4.9★", "label": "Valoración media" } },
        { "type": "stat", "settings": { "number": "30d", "label": "Devolución gratis" } }
      ]
    }
  ]
}
{% endschema %}
