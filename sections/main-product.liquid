<section class="page-width" data-product data-free-ship="{{ section.settings.free_ship | times: 100 }}">
  <div class="pdp">
    {%- comment -%} ===== Gallery ===== {%- endcomment -%}
    <div class="pdp__gallery">
      <div class="pdp__main-img">
        {%- if product.featured_image -%}
          <img data-main-img src="{{ product.featured_image | image_url: width: 900 }}" alt="{{ product.featured_image.alt | escape | default: product.title }}">
        {%- else -%}
          {% render 'media-placeholder', uid: 'pdp', label: 'foto producto' %}
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ===== Info ===== {%- endcomment -%}
    <div class="pdp__info">
      <h1 class="pdp__title">{{ product.title }}</h1>
      <div class="pdp__meta">
        {% render 'stars', rating: 5 %}
        <span>{{ section.settings.reviews_text }}</span>
        {%- if section.settings.sold_text != blank -%}
          <span class="sep">·</span><span>🔥 {{ section.settings.sold_text }}</span>
        {%- endif -%}
      </div>
      {%- if section.settings.show_viewers -%}
        <div class="urgency"><span class="pulse"></span> <span data-viewers>{{ section.settings.viewers_start }}</span> personas viendo esto ahora</div>
      {%- endif -%}

      {%- if section.settings.show_countdown -%}
        <div class="offer-divider">⚡ {{ section.settings.offer_label }}</div>
        <div class="countdown" data-countdown="{{ section.settings.countdown_hours }}" data-cd-key="{{ product.id }}">
          <div class="countdown__label">{{ section.settings.countdown_label }}</div>
          <div class="countdown__clock">
            <div class="countdown__unit"><span class="countdown__num" data-cd-h>23</span><small>Horas</small></div>
            <span class="countdown__sep">:</span>
            <div class="countdown__unit"><span class="countdown__num" data-cd-m>59</span><small>Mins</small></div>
            <span class="countdown__sep">:</span>
            <div class="countdown__unit"><span class="countdown__num" data-cd-s>59</span><small>Seg</small></div>
          </div>
        </div>
      {%- endif -%}

      {% form 'product', product %}
        {%- assign current = product.selected_or_first_available_variant -%}

        {%- comment -%} ===== Variant radio cards ===== {%- endcomment -%}
        {%- if product.variants.size > 1 -%}
          <div class="variant-list">
            {%- for variant in product.variants -%}
              {%- comment -%} derive a swatch color from the variant/option name {%- endcomment -%}
              {%- assign vname = variant.title | downcase -%}
              {%- assign swatch = '' -%}
              {%- if vname contains 'roj' or vname contains 'red' %}{% assign swatch = '#D0342C' %}
              {%- elsif vname contains 'verd' or vname contains 'green' %}{% assign swatch = '#3E8E5A' %}
              {%- elsif vname contains 'azul' or vname contains 'blue' %}{% assign swatch = '#2A6FB0' %}
              {%- elsif vname contains 'gris' or vname contains 'gray' or vname contains 'grey' %}{% assign swatch = '#9A9A9A' %}
              {%- elsif vname contains 'negr' or vname contains 'black' %}{% assign swatch = '#2A1B12' %}
              {%- elsif vname contains 'blanc' or vname contains 'white' %}{% assign swatch = '#F2EDE3' %}
              {%- elsif vname contains 'rosa' or vname contains 'pink' %}{% assign swatch = '#E58CA8' %}
              {%- elsif vname contains 'amarill' or vname contains 'yellow' %}{% assign swatch = '#F0A500' %}
              {%- elsif vname contains 'morad' or vname contains 'purpura' or vname contains 'purple' %}{% assign swatch = '#7A4FB0' %}
              {%- elsif vname contains 'naranj' or vname contains 'orange' %}{% assign swatch = '#E8702A' %}
              {%- else %}{% assign swatch = '#C9B79C' %}{% endif -%}
              <label class="variant-card {% if variant.id == current.id %}is-active{% endif %} {% unless variant.available %}sold-out{% endunless %}">
                {%- if forloop.index == section.settings.popular_index -%}
                  <span class="variant-card__flag">★ Más popular</span>
                {%- endif -%}
                <input type="radio" name="id" value="{{ variant.id }}" data-variant-radio {% if variant.id == current.id %}checked{% endif %} {% unless variant.available %}disabled{% endunless %}>
                <span class="dot"></span>
                <span class="variant-swatch" style="background:{{ swatch }}"></span>
                <span class="variant-card__main">
                  <span class="variant-card__name">{{ variant.title }}</span>
                  <span class="variant-card__sub">
                    {%- if variant.available -%}
                      {%- if variant.inventory_management and variant.inventory_quantity > 0 and variant.inventory_quantity <= 5 -%}
                        <span class="variant-card__stock low">● Quedan {{ variant.inventory_quantity }}</span>
                      {%- else -%}
                        <span class="variant-card__stock">● En stock</span>
                      {%- endif -%}
                    {%- else -%}
                      <span class="variant-card__stock low">● Agotado</span>
                    {%- endif -%}
                  </span>
                </span>
                <span class="variant-card__right">
                  <span class="variant-card__price">{{ variant.price | money }}</span>
                  {%- if variant.compare_at_price > variant.price -%}
                    <span class="variant-card__compare">{{ variant.compare_at_price | money }}</span>
                    {%- assign off = variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price -%}
                    <span class="variant-card__off">−{{ off }}%</span>
                  {%- endif -%}
                </span>
              </label>
            {%- endfor -%}
          </div>
        {%- else -%}
          <input type="hidden" name="id" value="{{ current.id }}" data-variant-id>
        {%- endif -%}

        <div class="pdp__buy">
          <span class="pdp__price">
            {%- if current.compare_at_price > current.price -%}
              <del data-compare>{{ current.compare_at_price | money }}</del>
            {%- else -%}
              <del data-compare style="display:none"></del>
            {%- endif -%}
            <span data-price>{{ current.price | money }}</span>
          </span>
          {%- if current.compare_at_price > current.price -%}
            <span class="pdp__save" data-save>Ahorras {{ current.compare_at_price | minus: current.price | money }}</span>
          {%- else -%}
            <span class="pdp__save" data-save style="display:none"></span>
          {%- endif -%}
        </div>

        {%- if section.settings.show_stockbar -%}
          <div class="stockbar">
            <div class="stockbar__top"><span>Stock de esta oferta</span><span><b data-stock-n>{{ section.settings.stock_count }}</b> unidades</span></div>
            <div class="stockbar__track"><div class="stockbar__fill" data-stock-fill style="width:32%"></div></div>
          </div>
        {%- endif -%}

        <div style="display:flex;gap:14px;align-items:center;margin-bottom:8px;">
          <div class="qty" data-qty>
            <button type="button" data-qty-minus aria-label="Menos">−</button>
            <input type="number" name="quantity" value="1" min="1" inputmode="numeric" aria-label="{{ 'products.product.quantity' | t }}">
            <button type="button" data-qty-plus aria-label="Más">+</button>
          </div>
        </div>

        <button type="submit" name="add" class="btn btn--primary btn--block btn--lg" data-add {% unless current.available %}disabled{% endunless %}>
          {% if current.available %}Añadir al carrito 🐾{% else %}Agotado{% endif %}
        </button>

        <p style="text-align:center;color:var(--color-ink-soft);font-size:.9rem;margin-top:12px;">🔒 Pago 100% seguro · {{ 'products.product.shipping_policy' | t }}</p>

        {%- if section.settings.show_shipbar -%}
          <div class="shipbar">
            <div class="shipbar__label">🚚 <span data-ship-msg>Envío gratis en pedidos +{{ section.settings.free_ship }}€</span></div>
            <div class="shipbar__track"><div class="shipbar__fill" data-ship-fill style="width:0%"></div></div>
          </div>
        {%- endif -%}

        <div class="pay">
          Pago seguro con
          <span class="pay__chip">VISA</span>
          <span class="pay__chip">Mastercard</span>
          <span class="pay__chip">PayPal</span>
          <span class="pay__chip">Bizum</span>
          <span class="pay__chip">G Pay</span>
        </div>
      {% endform %}

      <div class="trust">
        <div><span>🚀</span>Envío 8-18 días</div>
        <div><span>↩️</span>30 días devolución</div>
        <div><span>🛡️</span>Pago seguro</div>
      </div>

      <script type="application/json" data-variants-json>
        [
          {%- for v in product.variants -%}
            {"id": {{ v.id }}, "price": {{ v.price }}, "compare_at_price": {{ v.compare_at_price | default: 0 }}, "available": {{ v.available }}, "title": {{ v.title | json }}, "featured_image": {% if v.featured_image %}{{ v.featured_image | image_url: width: 900 | json }}{% else %}null{% endif %}, "stock": {% if v.inventory_management and v.inventory_quantity > 0 %}{{ v.inventory_quantity }}{% else %}null{% endif %}}{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
      </script>
    </div>
  </div>

  {%- comment -%} ===== Description + info accordions ===== {%- endcomment -%}
  <div class="pdp__desc">
    <div class="accordion">
      {%- if product.description != blank -%}
        <div class="acc-item open">
          <button class="acc-head" data-acc>{{ 'products.product.description' | t }} <span class="chev">+</span></button>
          <div class="acc-body"><div class="acc-body__inner rte">{{ product.description }}</div></div>
        </div>
      {%- endif -%}
      <div class="acc-item">
        <button class="acc-head" data-acc>Envío y entrega <span class="chev">+</span></button>
        <div class="acc-body"><div class="acc-body__inner">{{ section.settings.shipping_text }}</div></div>
      </div>
      <div class="acc-item">
        <button class="acc-head" data-acc>Devoluciones <span class="chev">+</span></button>
        <div class="acc-body"><div class="acc-body__inner">{{ section.settings.returns_text }}</div></div>
      </div>
    </div>
  </div>
</section>

{%- comment -%} ===== Sticky buy bar ===== {%- endcomment -%}
<div class="buybar">
  <div class="buybar__inner">
    <div class="buybar__thumb">
      {%- if product.featured_image -%}<img src="{{ product.featured_image | image_url: width: 96 }}" alt="">{%- endif -%}
    </div>
    <div class="buybar__info">
      <div class="buybar__name" data-bb-name>{{ product.title }}</div>
      <div class="buybar__price" data-bb-price>{{ product.selected_or_first_available_variant.price | money }}</div>
    </div>
    <button type="button" class="btn btn--primary" data-bb-add>Añadir al carrito 🐾</button>
  </div>
</div>

{% schema %}
{
  "name": "Producto",
  "settings": [
    { "type": "text", "id": "reviews_text", "label": "Texto de reseñas", "default": "4.9 · 214 reseñas" },
    { "type": "text", "id": "sold_text", "label": "Texto de ventas", "default": "1.2k vendidos" },
    { "type": "header", "content": "Urgencia / Prueba social" },
    { "type": "checkbox", "id": "show_viewers", "label": "Mostrar 'personas viendo'", "default": true },
    { "type": "range", "id": "viewers_start", "label": "Nº inicial de viewers", "min": 5, "max": 60, "step": 1, "default": 17 },
    { "type": "checkbox", "id": "show_stockbar", "label": "Mostrar barra de stock", "default": true },
    { "type": "range", "id": "stock_count", "label": "Unidades mostradas", "min": 1, "max": 50, "step": 1, "default": 8 },
    { "type": "header", "content": "Oferta / Countdown" },
    { "type": "checkbox", "id": "show_countdown", "label": "Mostrar countdown", "default": true },
    { "type": "text", "id": "offer_label", "label": "Etiqueta oferta", "default": "Oferta por tiempo limitado" },
    { "type": "text", "id": "countdown_label", "label": "Título del reloj", "default": "La oferta termina en" },
    { "type": "range", "id": "countdown_hours", "label": "Duración (horas)", "min": 1, "max": 72, "step": 1, "default": 24 },
    { "type": "header", "content": "Envío gratis" },
    { "type": "checkbox", "id": "show_shipbar", "label": "Mostrar barra de envío gratis", "default": true },
    { "type": "range", "id": "free_ship", "label": "Umbral envío gratis (€)", "min": 20, "max": 100, "step": 5, "default": 40 },
    { "type": "header", "content": "Variantes" },
    { "type": "range", "id": "popular_index", "label": "Variante 'Más popular' (posición)", "min": 0, "max": 10, "step": 1, "default": 2, "info": "0 = ninguna" },
    { "type": "header", "content": "Acordeones de info" },
    { "type": "richtext", "id": "shipping_text", "label": "Envío y entrega", "default": "<p>Procesamos tu pedido en 1-3 días laborables. Entrega estimada <b>8-18 días hábiles</b> con Ecoscooting y Correos. Envío gratis en pedidos +40€.</p>" },
    { "type": "richtext", "id": "returns_text", "label": "Devoluciones", "default": "<p>Tienes <b>30 días</b> para devolverlo sin preguntas. Si no estás satisfecho, te devolvemos el dinero.</p>" }
  ]
}
{% endschema %}
