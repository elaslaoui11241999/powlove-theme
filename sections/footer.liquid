<style>
.pw-footer{background:#2A1B12;color:#FBEFE2;padding:56px 0 28px;font-family:'Nunito',sans-serif}
.pw-footer__inner{max-width:1200px;margin:0 auto;padding:0 24px;display:grid;grid-template-columns:1.8fr 1fr 1fr 1fr;gap:40px;align-items:start}
@media(max-width:900px){.pw-footer__inner{grid-template-columns:1fr 1fr;gap:32px}}
@media(max-width:520px){.pw-footer__inner{grid-template-columns:1fr}}
.pw-footer__logo{font-family:'Fredoka',sans-serif;font-size:1.6rem;font-weight:700;color:#fff;display:flex;align-items:center;gap:8px;margin-bottom:12px;text-decoration:none}
.pw-footer__logo em{color:#E8702A;font-style:normal}
.pw-footer__tagline{font-size:.93rem;color:rgba(251,239,226,.6);line-height:1.7;max-width:32ch;margin:0 0 18px}
.pw-footer__soc{display:flex;gap:10px;flex-wrap:wrap}
.pw-footer__soc a{width:36px;height:36px;border-radius:9px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;color:rgba(251,239,226,.5);transition:all .2s;text-decoration:none}
.pw-footer__soc a:hover{background:#E8702A;color:#fff;border-color:#E8702A}
.pw-footer__soc svg{width:17px;height:17px;display:block}
.pw-footer__col h4{font-family:'Fredoka',sans-serif;font-size:.85rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#E8702A;margin:0 0 14px}
.pw-footer__col ul{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:9px}
.pw-footer__col a{font-size:.92rem;color:rgba(251,239,226,.55);text-decoration:none;transition:color .15s}
.pw-footer__col a:hover{color:#E8702A}
.pw-footer__bottom{max-width:1200px;margin:36px auto 0;padding:20px 24px 0;border-top:1px solid rgba(255,255,255,.09);text-align:center;font-size:.84rem;color:rgba(251,239,226,.3)}
</style>

