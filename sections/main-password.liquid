<section class="password-page">
  <div class="password-card">
    <div class="header__logo" style="justify-content:center;font-size:2rem;margin-bottom:8px;">🐾 {{ settings.logo_text | default: shop.name }}</div>
    <h1>{{ section.settings.heading }}</h1>
    <p style="color:var(--color-ink-soft);">{{ section.settings.subtext }}</p>

    {% form 'customer', class: 'password-form' %}
      <input type="hidden" name="contact[tags]" value="prelaunch">
      <div class="newsletter__form" style="margin:20px auto 0;max-width:420px;">
        <input type="email" name="contact[email]" placeholder="Tu correo electrónico" required>
        <button type="submit" class="btn btn--primary btn--lg">Avísame 🐾</button>
      </div>
      {%- if form.posted_successfully? -%}<p style="margin-top:12px;color:#3E8E5A;font-weight:700;">¡Gracias! Te avisaremos.</p>{%- endif -%}
    {% endform %}

    <div style="margin-top:28px;">
      <details class="password-login">
        <summary>Entrar con contraseña</summary>
        {% form 'storefront_password' %}
          {{ form.errors | default_errors }}
          <div class="newsletter__form" style="margin:14px auto 0;max-width:420px;">
            <input type="password" name="password" placeholder="Contraseña" autocomplete="off">
            <button type="submit" class="btn btn--ghost btn--lg">Entrar</button>
          </div>
        {% endform %}
      </details>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contraseña",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Estamos preparando algo bonito 🐾" },
    { "type": "textarea", "id": "subtext", "label": "Texto", "default": "Nuestra tienda abre muy pronto. Déjanos tu correo y serás de los primeros en saberlo." }
  ]
}
{% endschema %}
