<section class="section">
  <div class="page-width">
    <div class="account-top">
      <div>
        <span class="eyebrow">🐾 Mi cuenta</span>
        <h1>Hola, {{ customer.first_name | default: 'amante de mascotas' }}</h1>
      </div>
      <a href="{{ routes.account_logout_url }}" class="btn btn--ghost">Cerrar sesión</a>
    </div>

    <div class="account-grid">
      <div>
        <h3 style="font-size:1.2rem;">Mis pedidos</h3>
        {%- if customer.orders.size > 0 -%}
          <div class="order-table">
            <div class="order-table__head"><span>Pedido</span><span>Fecha</span><span>Total</span><span>Estado</span></div>
            {%- for order in customer.orders -%}
              <a href="{{ order.customer_url }}" class="order-row">
                <span><b>{{ order.name }}</b></span>
                <span>{{ order.created_at | date: '%d/%m/%Y' }}</span>
                <span>{{ order.total_net_amount | money }}</span>
                <span class="order-status">{{ order.financial_status_label }}</span>
              </a>
            {%- endfor -%}
          </div>
        {%- else -%}
          <p style="color:var(--color-ink-soft);">Aún no has hecho ningún pedido. <a href="{{ routes.all_products_collection_url }}" style="color:var(--color-accent-dark);font-weight:800;">Empieza a comprar 🐾</a></p>
        {%- endif -%}
      </div>

      <aside class="account-card">
        <h3 style="font-size:1.1rem;">Dirección</h3>
        {%- if customer.default_address -%}
          <div class="rte">{{ customer.default_address | format_address }}</div>
        {%- else -%}
          <p style="color:var(--color-ink-soft);">No tienes direcciones guardadas.</p>
        {%- endif -%}
        <a href="{{ routes.account_addresses_url }}" class="btn btn--ghost btn--block" style="margin-top:12px;">Gestionar direcciones</a>
      </aside>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Cuenta", "settings": [] }
{% endschema %}
