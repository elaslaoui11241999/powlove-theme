<script>
function buyPack(btn){
  btn.textContent = 'Procesando...';
  btn.disabled = true;
  /* Los 3 productos del pack — primera variante disponible de cada uno */
  var items = [
    {id: 54076744270166, quantity: 1},  /* Recogedor con Linterna LED */
    {id: 54076744368470, quantity: 1},  /* Correa Retráctil 3m */
    {id: 54076745023830, quantity: 1}   /* Cinturón de Seguridad */
  ];
  fetch('/cart/clear.js', {method:'POST'})
    .then(function(){
      return fetch('/cart/add.js',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({items:items})
      });
    })
    .then(function(){ window.location.href='/checkout?discount=PAWLOVE10'; })
    .catch(function(){
      btn.textContent='Quiero el pack 🐾';
      btn.disabled=false;
      alert('Error al añadir el pack. Inténtalo de nuevo.');
    });
}

function buyNow(handle, el){
  var btn = el.querySelector('button');
  if(btn){ btn.textContent = 'Procesando...'; btn.disabled = true; }
  fetch('/products/' + handle + '.js')
    .then(function(r){ return r.json(); })
    .then(function(p){
      var vid = p.variants[0].id;
      return fetch('/cart/add.js',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({id:vid,quantity:1})
      });
    })
    .then(function(){ window.location.href = '/checkout'; })
    .catch(function(){
      if(btn){ btn.textContent = 'Comprar ahora 🐾'; btn.disabled = false; }
      window.location.href = '/collections/all';
    });
}

/* ===== Spotlight: color/talla → foto grande + variante + comprar ===== */
var _sp = {
  scooper:  { vid: null },
  correa:   { col: null, sz: '3m', vid: null, variants: [] },
  cinturon: { vid: null }
};

(function initSpotlights(){
  /* Scooper: vid del primer swatch seleccionado */
  var s = document.querySelector('#scooper .copt--photo.sel[data-vid]');
  if (s) _sp.scooper.vid = s.dataset.vid;

  /* Correa: parsear JSON + init color + calcular variante */
  var cd = document.getElementById('sp-correa-data');
  if (cd) {
    try { _sp.correa.variants = JSON.parse(cd.textContent); } catch(e){}
    var fc = document.querySelector('#correa .copt--photo.sel[data-col]');
    if (fc) _sp.correa.col = fc.dataset.col;
    _spCorreaSync();
  }

  /* Cinturón: vid del primer swatch seleccionado */
  var c = document.querySelector('#cinturon .copt--photo.sel[data-vid]');
  if (c) _sp.cinturon.vid = c.dataset.vid;
})();

function _spCorreaSync(){
  var v = _sp.correa.variants.find(function(x){
    return x.col === _sp.correa.col && x.sz === _sp.correa.sz;
  });
  if (v) {
    _sp.correa.vid = v.id;
    var img = document.getElementById('sp-correa-img');
    if (img && v.img) img.src = v.img;
  }
}

function spColorClick(btn, spotId){
  /* Visual: marcar seleccionado en este colorrow */
  btn.closest('.colorrow').querySelectorAll('.copt--photo').forEach(function(b){ b.classList.remove('sel'); });
  btn.classList.add('sel');

  if (spotId === 'correa') {
    _sp.correa.col = btn.dataset.col;
    _spCorreaSync();
  } else {
    _sp[spotId].vid = btn.dataset.vid;
    var img = document.getElementById('sp-' + spotId + '-img');
    if (img && btn.dataset.img) img.src = btn.dataset.img;
  }
}

function spSzClick(btn){
  btn.closest('.colorrow').querySelectorAll('.copt--sz').forEach(function(b){ b.classList.remove('sel'); });
  btn.classList.add('sel');
  _sp.correa.sz = btn.dataset.sz;
  _spCorreaSync();
}

function spBuy(spotId){
  var vid = _sp[spotId].vid;
  if (!vid) return;
  var btn = document.getElementById('sp-' + spotId + '-buy');
  var orig = btn ? btn.textContent : '';
  if (btn){ btn.textContent = 'Procesando...'; btn.disabled = true; }
  fetch('/cart/add.js',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({id:parseInt(vid),quantity:1})
  })
  .then(function(){ window.location.href = '/cart'; })
  .catch(function(){
    if (btn){ btn.textContent = orig; btn.disabled = false; }
  });
}

function toggleSoporte(e){
  e.stopPropagation();
  document.getElementById('soporte-popup').classList.toggle('show');
}
document.addEventListener('click',function(){
  var p=document.getElementById('soporte-popup');
  if(p) p.classList.remove('show');
});
document.getElementById('soporte-popup').addEventListener('click',function(e){e.stopPropagation();});
</script>

<script>
  (function(){
    document.documentElement.classList.add('js');
    var els = document.querySelectorAll('.reveal');
    if('IntersectionObserver' in window){
      var io = new IntersectionObserver(function(es){ es.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target);} }); }, {threshold:.12});
      els.forEach(function(el){ io.observe(el); });
      setTimeout(function(){ els.forEach(function(el){ el.classList.add('in'); }); }, 2200);
    } else { els.forEach(function(el){ el.classList.add('in'); }); }
    document.addEventListener('click', function(e){
      var c = e.target.closest('[data-c]'); if(c){ c.parentElement.querySelectorAll('[data-c]').forEach(function(b){b.classList.remove('sel');}); c.classList.add('sel'); }
      var s = e.target.closest('[data-s]'); if(s){ s.parentElement.querySelectorAll('[data-s]').forEach(function(b){b.classList.remove('sel');}); s.classList.add('sel'); }
    });
  })();
</script>
