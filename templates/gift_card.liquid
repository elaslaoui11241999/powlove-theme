<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ 'gift_cards.issued.title' | t: value: gift_card.initial_value | money, shop: shop.name }}</title>
  {{ 'base.css' | asset_url | stylesheet_tag }}
  <style>
    :root{ --color-bg:{{ settings.color_bg }}; --color-surface:{{ settings.color_surface }}; --color-ink:{{ settings.color_ink }}; --color-accent:{{ settings.color_accent }}; --color-border:{{ settings.color_border }}; --radius:{{ settings.corner_radius }}px; }
    body{ display:grid; place-items:center; min-height:100vh; }
    .gc{ background:var(--color-surface); border:1px solid var(--color-border); border-radius:24px; padding:40px; max-width:440px; text-align:center; }
    .gc__amount{ font-family:'Domine',serif; font-size:3rem; color:var(--color-accent); }
    .gc__code{ font-family:monospace; font-size:1.3rem; letter-spacing:.1em; background:var(--color-bg); border:1px dashed var(--color-border); border-radius:12px; padding:14px; margin:18px 0; }
  </style>
</head>
<body>
  <div class="gc">
    <div style="font-size:2.4rem;">🐾</div>
    <h1>{{ shop.name }}</h1>
    <p>Tu tarjeta regalo</p>
    <div class="gc__amount">{{ gift_card.initial_value | money }}</div>
    <div class="gc__code">{{ gift_card.code | format_code }}</div>
    {{ gift_card.qr_identifier }}
    <a href="{{ shop.url }}" class="btn btn--primary btn--lg" style="margin-top:10px;">Ir a la tienda</a>
  </div>
</body>
</html>
